# .env.local — copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Get these from your Neon project dashboard → Connection Details
# Use "Pooled connection" for DATABASE_URL, "Direct connection" for DIRECT_URL
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/edn-reunion?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/edn-reunion?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"

# The shared passphrase members use to log in
LOGIN_PASSPHRASE="world-citizens-2006"

# Admin passphrase (separate, extra-secret)
ADMIN_PASSPHRASE="REPLACE_WITH_ADMIN_SECRET"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# On Vercel, set this to your production URL:
# NEXT_PUBLIC_APP_URL="https://edn-reunion.vercel.app"

# ─── Uploadthing (file uploads) ───────────────────────────────────────────────
# Get from https://uploadthing.com → your project
UPLOADTHING_SECRET="sk_live_REPLACE_ME"
UPLOADTHING_APP_ID="REPLACE_ME"
