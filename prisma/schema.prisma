// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth
  email         String?   @unique
  role          Role      @default(MEMBER)

  // Profile
  fullName      String?
  birthday      DateTime?
  phone         String?   @unique
  city          String?
  state         String?
  country       String?
  latitude      Float?
  longitude     Float?
  studyPeriods  StudyPeriod[]

  // Then & Now photos
  photoThen     String?   // URL — old school photo
  photoNow      String?   // URL — current photo

  // RSVP
  rsvp          Rsvp?

  // Content contributions
  memories      Memory[]
  comments      MemoryComment[]
  memoryTags    MemoryTag[]
  videoMessage  VideoMessage?
  activityLogs  ActivityLog[]

  sessions      Session[]
}

model StudyPeriod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearStart Int
  yearEnd   Int

  @@unique([userId, yearStart, yearEnd])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Rsvp {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  isAttending     Boolean
  guestAdults     Guest[]  @relation("AdultGuests")
  guestChildren   Guest[]  @relation("ChildGuests")

  foodPreference  FoodPreference  @default(BARBECUE)
  drinkPreference DrinkPreference @default(NON_ALCOHOLIC)

  paymentConfirmed Boolean @default(false)
  paymentProofUrl  String?
}

model Guest {
  id          String  @id @default(cuid())
  fullName    String
  age         Int?    // only for children

  foodPreference  FoodPreference  @default(BARBECUE)
  drinkPreference DrinkPreference @default(NON_ALCOHOLIC)

  // Relations — a guest is either an adult or child guest on an RSVP
  adultRsvp   Rsvp?   @relation("AdultGuests", fields: [adultRsvpId], references: [id], onDelete: Cascade)
  adultRsvpId String?
  childRsvp   Rsvp?   @relation("ChildGuests", fields: [childRsvpId], references: [id], onDelete: Cascade)
  childRsvpId String?
}

model Memory {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      MemoryType
  era       MemoryEra?
  sortOrder Int?        // admin-controlled display order for photos
  title     String?
  content   String?     // text for quotes/stories
  author    String?     // quoted person (for QUOTE type)
  mediaUrl  String?     // URL for photos/videos
  approved  Boolean     @default(true)

  comments  MemoryComment[]
  tags      MemoryTag[]
}

model MemoryTag {
  id       String @id @default(cuid())
  memoryId String
  memory   Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([memoryId, userId])
}

model MemoryComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  memoryId  String
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  content   String
}

model VideoMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoUrl  String
  approved  Boolean  @default(true)
}

model EventConfig {
  id                   String   @id @default("singleton")
  updatedAt            DateTime @updatedAt
  date                 String   @default("XX/XX/XXXX")
  time                 String   @default("12:00 - 20:00")
  venueName            String   @default("Clube da Aeronáutica")
  venueAddress         String   @default("SCEN Trecho 1 Conjunto 6")
  venueCity            String   @default("Brasília, DF — Brasil")
  mapsUrl              String   @default("")
  costPerPerson        Int      @default(160)
  costPerPersonReduced Int      @default(40)
  costPerChild         Int      @default(80)
  currency             String   @default("BRL")
  pixKey               String   @default("")
  pixRecipientName     String   @default("EDN REUNION 2006")
  pixCity              String   @default("BRASILIA")
  whatsIncluded        String[] @default(["Churrasco", "Bebidas não-alcoólicas", "Chopp"])
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String   // UPLOAD, EDIT, SOFT_DELETE, RESTORE, BATCH_ERA, BATCH_OWNER, BATCH_REORDER
  memoryId  String?
  details   Json?    // { type, title, era, count, etc. }
}

model InviteToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}

enum Role {
  MEMBER
  ADMIN
}

enum MemoryType {
  PHOTO
  VIDEO
  QUOTE
  STORY
}

enum MemoryEra {
  KINDERGARTEN
  LOWER_SCHOOL
  MIDDLE_SCHOOL
  HIGH_SCHOOL
  ADULT_LIFE
}

enum FoodPreference {
  BARBECUE
  VEGETARIAN
  NO_FOOD
}

enum DrinkPreference {
  CHOPP
  NON_ALCOHOLIC
  OWN_DRINKS
}
